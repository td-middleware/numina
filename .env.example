# Numina Environment Configuration

# OpenAI API Key (if using OpenAI)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API Key (if using Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Numina Configuration
NUMINA_LOG_LEVEL=info
NUMINA_WORKSPACE=~/.numina/workspace

# MCP Configuration
MCP_AUTO_CONNECT=false

# Collaboration Settings
NUMINA_MAX_PARALLEL_AGENTS=5
NUMINA_CONSENSUS_REQUIRED=false
